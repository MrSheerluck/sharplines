# Database
DATABASE_URL=postgres://sharplines:sharplines@localhost:5432/sharplines
# JWT
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
JWT_ACCESS_EXPIRY=15
JWT_REFRESH_EXPIRY=7
# Server
BACKEND_PORT=3000
FRONTEND_PORT=5173
FRONTEND_URL=http://localhost:5173
# Encryption (for Lichess tokens)
ENCRYPTION_KEY=another-32-char-key-for-aes-encryption!!
# Resend Email
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
EMAIL_FROM_NAME=Sharplines
# Lichess OAuth
LICHESS_CLIENT_ID=your_lichess_app_id
LICHESS_CLIENT_SECRET=your_lichess_app_secret
LICHESS_REDIRECT_URI=http://localhost:3000/auth/lichess/callback
